rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOrgMember(orgId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    function orgRole(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role;
    }

    function isOrgAdmin(orgId) {
      return isOrgMember(orgId) && orgRole(orgId) in ['owner', 'admin'];
    }

    // Viewer: read workspace data only. Member / admin / owner can change projects, tasks, time, etc.
    function canMutateOrgContent(orgId) {
      return isOrgMember(orgId) && orgRole(orgId) in ['owner', 'admin', 'member'];
    }

    // Existing org: use get(). Same-transaction org create + first owner member: get() may not see the new org yet; use getAfter().
    function isOrgOwnerUser(orgId) {
      return signedIn() && (
        (exists(/databases/$(database)/documents/organizations/$(orgId)) &&
          get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid) ||
        getAfter(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid
      );
    }

    // Read-only client portal snapshots (document ID = secret token). No list queries.
    match /portalLinks/{token} {
      allow get: if true;
      allow list: if false;
      allow create: if signedIn() &&
        request.resource.data.orgId is string &&
        request.resource.data.projectId is string &&
        request.resource.data.projectName is string &&
        request.resource.data.taskCounts is map &&
        isOrgMember(request.resource.data.orgId) &&
        isOrgAdmin(request.resource.data.orgId);
      allow update: if signedIn() &&
        resource.data.orgId is string &&
        isOrgMember(resource.data.orgId) &&
        isOrgAdmin(resource.data.orgId);
      allow delete: if signedIn() &&
        resource.data.orgId is string &&
        isOrgMember(resource.data.orgId) &&
        isOrgAdmin(resource.data.orgId);
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId) || (signedIn() && resource.data.ownerId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOrgAdmin(orgId);
      allow delete: if false;

      match /members/{memberId} {
        // Invitee must read their own member doc (even if missing) to complete invite transaction.
        allow read: if isOrgMember(orgId) ||
          (signedIn() && request.auth.uid == memberId);
        allow create: if signedIn() && request.auth.uid == memberId && (
          request.resource.data.role in ['admin', 'member', 'viewer'] ||
          (request.resource.data.role == 'owner' && isOrgOwnerUser(orgId))
        );
        allow update: if isOrgAdmin(orgId);
        allow delete: if isOrgAdmin(orgId);
      }

      match /invites/{inviteId} {
        allow read: if signedIn() && (
          isOrgMember(orgId) ||
          (
            resource.data.email is string &&
            request.auth.token.email != null &&
            resource.data.email.lower() == request.auth.token.email.lower()
          )
        );
        allow create: if isOrgAdmin(orgId)
          && request.resource.data.email is string
          && request.resource.data.email.size() > 3
          && request.resource.data.role in ['admin', 'member', 'viewer']
          && request.resource.data.invitedByUid == request.auth.uid
          && request.resource.data.organizationName is string;
        allow delete: if isOrgAdmin(orgId) ||
          (
            signedIn() &&
            resource.data.email is string &&
            request.auth.token.email != null &&
            resource.data.email.lower() == request.auth.token.email.lower()
          );
        allow update: if false;
      }

      match /clients/{clientId} {
        allow read: if isOrgMember(orgId);
        allow create, update, delete: if canMutateOrgContent(orgId);
      }

      match /projects/{projectId} {
        allow read: if isOrgMember(orgId);
        allow create, update, delete: if canMutateOrgContent(orgId);

        match /tasks/{taskId} {
          allow read: if isOrgMember(orgId);
          allow create, update, delete: if canMutateOrgContent(orgId);
        }
      }

      match /timeEntries/{entryId} {
        allow read: if isOrgMember(orgId);
        allow create: if canMutateOrgContent(orgId) && request.resource.data.userId == request.auth.uid;
        allow update, delete: if canMutateOrgContent(orgId) && resource.data.userId == request.auth.uid;
      }

      match /taskComments/{commentId} {
        allow read: if isOrgMember(orgId);
        allow create: if canMutateOrgContent(orgId) && request.resource.data.userId == request.auth.uid;
        allow update, delete: if canMutateOrgContent(orgId) && resource.data.userId == request.auth.uid;
      }

      match /invoices/{invoiceId} {
        allow read: if isOrgMember(orgId);
        allow create, update: if canMutateOrgContent(orgId);
        allow delete: if isOrgAdmin(orgId);
      }
    }
  }
}
