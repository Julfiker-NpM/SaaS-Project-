// FlowPM — database schema from FlowPM_Build_Guide.docx
// Local: SQLite. Production: point DATABASE_URL to Supabase Postgres.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String?  @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  plan         String   @default("free") // free | pro | agency

  ownedOrganizations Organization[] @relation("OrganizationOwner")
  orgMemberships     OrgMember[]
  projectsCreated    Project[]      @relation("ProjectCreator")
  tasksAssigned      Task[]         @relation("TaskAssignee")
  taskComments       TaskComment[]
  timeEntries        TimeEntry[]
}

model Organization {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  ownerId          String   @map("owner_id")
  plan             String   @default("free")
  stripeCustomerId String?  @map("stripe_customer_id")
  createdAt        DateTime @default(now()) @map("created_at")

  owner   User         @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members OrgMember[]
  projects Project[]
  clients  Client[]
  invoices Invoice[]
}

model OrgMember {
  id        String    @id @default(cuid())
  orgId     String    @map("org_id")
  userId    String    @map("user_id")
  role      String    @default("member") // owner | admin | member | viewer
  invitedAt DateTime? @map("invited_at")
  joinedAt  DateTime? @map("joined_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

model Client {
  id          String   @id @default(cuid())
  orgId       String   @map("org_id")
  name        String
  email       String?
  company     String?
  logoUrl     String?  @map("logo_url")
  portalToken String?  @unique @map("portal_token")
  createdAt   DateTime @default(now()) @map("created_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projects Project[]
  invoices Invoice[]

  @@index([orgId])
}

model Project {
  id          String    @id @default(cuid())
  orgId       String    @map("org_id")
  name        String
  description String?
  clientId    String?   @map("client_id")
  status      String    @default("active")
  color       String    @default("#534AB7")
  dueDate     DateTime? @map("due_date")
  createdById String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  client    Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy User         @relation("ProjectCreator", fields: [createdById], references: [id])
  tasks     Task[]
  timeEntries TimeEntry[]

  @@index([orgId])
  @@index([clientId])
}

model Task {
  id             String    @id @default(cuid())
  projectId      String    @map("project_id")
  title          String
  description    String?
  assigneeId     String?   @map("assignee_id")
  status         String    @default("todo") // todo | in_progress | review | done
  priority       String    @default("medium")
  dueDate        DateTime? @map("due_date")
  estimatedHours Float?    @map("estimated_hours")
  position       Int       @default(0)
  createdAt      DateTime  @default(now()) @map("created_at")

  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   User?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments   TaskComment[]
  timeEntries TimeEntry[]

  @@index([projectId])
  @@index([assigneeId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TimeEntry {
  id          String   @id @default(cuid())
  taskId      String?  @map("task_id")
  projectId   String   @map("project_id")
  userId      String   @map("user_id")
  description String?
  hours       Float
  date        DateTime
  billable    Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  task    Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
}

model Invoice {
  id          String    @id @default(cuid())
  orgId       String    @map("org_id")
  clientId    String?   @map("client_id")
  number      String
  status      String    @default("draft") // draft | sent | paid
  totalAmount Float     @map("total_amount")
  dueDate     DateTime? @map("due_date")
  sentAt      DateTime? @map("sent_at")
  paidAt      DateTime? @map("paid_at")

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  client Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@unique([orgId, number])
  @@index([orgId])
}
