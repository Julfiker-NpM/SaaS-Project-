rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function owns(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    // Profile synced on Google sign-in (doc id = auth uid)
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /products/{productId} {
      allow read: if resource != null && owns(resource.data);
      allow create: if owns(request.resource.data);
      allow update, delete: if resource != null && owns(resource.data);
    }

    match /customers/{customerId} {
      allow read: if resource != null && owns(resource.data);
      allow create: if owns(request.resource.data);
      allow update, delete: if resource != null && owns(resource.data);
    }

    match /orders/{orderId} {
      allow read: if resource != null && owns(resource.data);
      allow create: if owns(request.resource.data);
      allow update, delete: if resource != null && owns(resource.data);
    }
  }
}
