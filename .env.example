# Firebase — Project settings → General → Your apps (Web)
# Vercel: add these under Project → Settings → Environment Variables, then redeploy (NEXT_PUBLIC_* are build-time).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Deploy Firestore rules (after enabling Firestore in console):
#   npm i -g firebase-tools
#   firebase login
#   firebase init firestore   # or use existing firebase.json in this repo)
#   firebase deploy --only firestore:rules

# Optional: automatic invitation emails (Team → Invite member)
FIREBASE_SERVICE_ACCOUNT_JSON=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
NEXT_PUBLIC_APP_URL=

# Optional: Bangladesh mobile banking — checkout opens from Settings → Manage subscription.
# Public URL (also used at build time for client). Server-only overrides work for /api/checkout/* redirects:
NEXT_PUBLIC_BKASH_CHECKOUT_URL=
NEXT_PUBLIC_NAGAD_CHECKOUT_URL=
# Optional: show “pay to this number” on the payment confirmation page
NEXT_PUBLIC_BKASH_MERCHANT_NUMBER=
NEXT_PUBLIC_NAGAD_MERCHANT_NUMBER=

# Optional: Stripe upgrade / portal (see lib/flowpm/plan-limits.ts)
NEXT_PUBLIC_STRIPE_CHECKOUT_PRO_URL=
NEXT_PUBLIC_STRIPE_CHECKOUT_AGENCY_URL=
NEXT_PUBLIC_STRIPE_CUSTOMER_PORTAL_URL=
