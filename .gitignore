**/*.db
**/*.db-journal
**/*.sqlite

# Logs & debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS & editors
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# TypeScript
*.tsbuildinfo

# Vercel
**/.vercel

# Keys & coverage
*.pem
**/coverage/

# Prisma generated (if output customized)
**/lib/generated/prisma
